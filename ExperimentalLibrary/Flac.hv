FlacTest := !() -> void
{
	tstData := FSGetFile("jmono.flac").GetBlob()


	eng := SoundEngine()
	eng.CreateTask()
	snd := eng.LoadFromFLAC(tstData)
	// snd.buf = resIdx
	eng.PlaySound(snd).AwaitCompletion()
}

FLACDecodeCtx := class
{
	ReadPtr := u8^
	ReadSize := size_t
	RedData := int

	ResPtr := u8^
	ResSize := int
}

FLAC__FrameHeader := class
{
	BlockSize := u32
	SampleRate := u32
	Channels := u32
	ChannelAssigment := s32
	BitsPerSample := u32
	Number := s32
	CRC := u8
}

