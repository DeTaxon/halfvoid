OpusTest := !() -> void
{
	dat := FSGetFile("tetris.opus").GetBlob()

	eng := SoundEngine()
	eng.CreateTask()
	snd := eng.LoadFromOpus(dat)

	// snd.buf = resIdx
	eng.PlaySound(snd).AwaitCompletion()
	eng.Stop()
	// TSleep(2.0)

}

HVOpusDecoder := class
{
	Rate := int
	ChannelsCount := int

	LoadHeader := !(Blob^ blb) -> void
	{
		iter := blb.GetPointer()->{u8^}[28]& // skip ogg header
		
		header := iter->{OpusHeader^}

		ChannelsCount = header.Channels

