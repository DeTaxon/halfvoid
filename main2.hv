	z := CreatedTestClass
	z.first = 13
}

#Module(
	cls := TypeClass^

	GetItem := virtual !(Str name) -> HV_Object^
	{
		if name == "CreatedTestClass"
		{
			return cls->{HV_Object^}?

			cls = HV.CreateClass2()

			cls.GetFieldsCount()

			cls.AddField("first",HV.GetType("int"))

			printf("after created %i <%s>\n",cls.GetFieldsCount(),cls.GetDebugStr())

			return cls->{HV_Object^}
		}

	}
)


