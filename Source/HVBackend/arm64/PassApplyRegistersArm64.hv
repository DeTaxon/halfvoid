PassApplyRegistersArm64 := !(MCFunction^ fnc) -> MCFunction^
{
	bldr := MakeGreedyPass(fnc,4,6)

	c := ref bldr.cmdsSize
	cPtr := bldr.cmds.GetPointer()

	o := ref bldr.objsSize
	oPtr := bldr.objs.GetPointer()

	i := 0
	while i < fnc.Lines.Size()
	{
		line := ref fnc.Lines[i]
		switch line.opcode
		{
		case "debug_set_file"
		case "debug_set_line"
		case "debug_block_start"
		case "debug_block_end"
		case "jmp"
		case "label"
			cPtr[c++] = line

		case "call_start"
			callObj := ref fnc.Objects[fnc.Lines[i].var2]

			i += 1

			intReg := 0

			while fnc.Lines[i].opcode != "call_end"
			{
				cPtr[c++] = MCLine("mov",bldr.PushArmReg(intReg++,GTypeVoidP),fnc.Lines[i].var1)
				i += 1
			}

			if callObj is MCConstFunction
			{
				fncReg := bldr.PushArmReg(9,GTypeVoidP)

				fncHV := callObj&->{MCConstFunction^}.GetValue()

				if fncHV is ResistFunc {
					fncHV = fncHV.base
				}

				if fncHV is BoxFuncDeclare {
					ptr := GInterpCntx.DeclareToPtr(fncHV->{BoxFuncDeclare^})

					callFunc := bldr.PushPtr(ptr)

					cPtr[c++] = MCLine("mov",fncReg,callFunc)
					cPtr[c++] = MCLine("call_start",fncReg)
				}else{
					assert(false)
				}
			}else{
				assert(false,"unknown function call")
			}


		case "mov"
			ob1 := ref oPtr[line.var1]
			ob2 := ref oPtr[line.var2]
			if ob1 is MCVariable and (ob2 is MCConstString or ob2 is MCConstS64 or ob2 is MCConstInteger)
			{
				newReg := bldr.PushArmReg(0,GTypeVoidP)
				cPtr[c++] = MCLine("mov",newReg,line.var2)
				cPtr[c++] = MCLine("mov",line.var1,newReg)
			}else{
				assert(false,"unknown move")
			}
		case void
			// assert(false,"unsupported opcode")
		}
		i += 1
	}
	
	return bldr.GenerateFunc()
}
