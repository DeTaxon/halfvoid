
va_list := type void^

vaListLoadInt := !(va_list^ va) -> u64
{
	result = va^->{u64^}^
	va->{size_t^}^ += void^->TypeSize
}
vaListLoadFloat := !(va_list^ va) -> double
{
	result = va->{double^^}^^
	va->{size_t^}^ += void^->TypeSize
}
vaListLoadVec4f := !(va_list^ va) -> vec4f
{
	result = va->{vec4f^^^}^^^
	va->{size_t^}^ += void^->TypeSize
}
