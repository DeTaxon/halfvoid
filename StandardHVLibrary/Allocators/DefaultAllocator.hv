

DefaultAllocator := class extends IAllocator
{
	AllocMem := virtual !(int size,bool dirty) -> void^
	{
		if dirty
		{
			result = malloc(size)
		}else{
			result = calloc(1,size)
		}
		if #Var("TracyMem") and ___tracy_emit_memory_alloc_callstack != null
		{
			___tracy_emit_memory_alloc_callstack(result,size,0,0)
		}
	}
	FreeMem := virtual !(void^ mem) -> void
	{
		if #Var("TracyMem")
		{
			___tracy_emit_memory_free_callstack(mem,0,0)
		}
		free(mem)
	}
}
